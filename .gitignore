# PhysicsLab AI — .gitignore

# Environment (NEVER commit credentials!)
.env
*.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Uploads (exclude actual files, keep folder)
uploads/*
!uploads/.gitkeep

# Logs
*.log
logs/
