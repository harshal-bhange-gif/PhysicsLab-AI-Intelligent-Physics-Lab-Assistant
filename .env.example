# ─────────────────────────────────────────────────────────────────────────────
# PhysicsLab AI — Environment Variables Template
# Copy this file to .env and fill in your IBM Cloud credentials
# NEVER commit the actual .env file to version control!
# ─────────────────────────────────────────────────────────────────────────────

# ── IBM Cloud API Key ─────────────────────────────────────────────────────────
# Get from: https://cloud.ibm.com → Manage → Access (IAM) → API keys
IBM_API_KEY=CEUKkecmJDg1waxG9sl7HMIiiCYikyYIcbpA0vVxhj2Y

# ── IBM watsonx.ai Project ID ─────────────────────────────────────────────────
# Get from: https://dataplatform.cloud.ibm.com → Projects → Your Project → Settings
IBM_PROJECT_ID=0ef654bb-ebe0-4f26-94e5-d6ff9698c2d2

# ── IBM watsonx.ai Region URL ─────────────────────────────────────────────────
# Dallas (us-south):  https://us-south.ml.cloud.ibm.com
# London (eu-gb):     https://eu-gb.ml.cloud.ibm.com
# Frankfurt (eu-de):  https://eu-de.ml.cloud.ibm.com
# Tokyo (jp-tok):     https://jp-tok.ml.cloud.ibm.com
IBM_REGION_URL=https://us-south.ml.cloud.ibm.com

# ── IBM Granite Model ID ──────────────────────────────────────────────────────
# Available models depend on your watsonx.ai project/plan.
# To list models available in YOUR project, run:
#   python -c "from ibm_watsonx_ai import Credentials,APIClient; c=APIClient(Credentials(url='https://us-south.ml.cloud.ibm.com',api_key='YOUR_KEY')); c.set.default_project('YOUR_PROJECT'); print([m['model_id'] for m in c.foundation_models.get_specs()['resources']])"
#
# Common instruct models (check your project for availability):
#   ibm/granite-4-h-small                         (IBM Granite 4 — recommended)
#   ibm/granite-3-3-8b-instruct                   (Granite 3.3 8B instruct)
#   meta-llama/llama-3-3-70b-instruct             (Llama 3.3 70B)
#   mistralai/mistral-small-3-1-24b-instruct-2503 (Mistral Small)
GRANITE_MODEL=ibm/granite-4-h-small

# ── Flask Settings ────────────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=false
FLASK_ENV=production

# ── Application Settings ──────────────────────────────────────────────────────
APP_NAME=PhysicsLab AI
APP_VERSION=1.0.0
